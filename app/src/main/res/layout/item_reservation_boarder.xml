<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Top row: property name + status badge -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvResPropertyName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Property Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:id="@+id/tvResStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="#FF9800"/>

        </LinearLayout>

        <!-- Unit name -->
        <TextView
            android:id="@+id/tvResUnitName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Whole property"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="4dp"/>

        <!-- Move-in date -->
        <TextView
            android:id="@+id/tvResMoveInDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Move-in: 2025-08-01"
            android:textSize="13sp"
            android:textColor="@color/textPrimary"/>

        <!-- Owner contact — only visible when approved -->
        <LinearLayout
            android:id="@+id/layoutOwnerContact"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            android:background="#F1FFF4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Owner Contact"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvResOwnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Name"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:id="@+id/tvResOwnerEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉ email"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvResOwnerPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 phone"
                android:textSize="13sp"
                android:textColor="@color/textPrimary"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Cancel button — only visible when pending -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelReservation"
            android:text="Cancel Request"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#FF5252"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp"
            android:visibility="gone"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>