<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Cover Image -->
        <ImageView
            android:id="@+id/imageDetail"
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Dark overlay -->
        <View
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:background="#66000000"
            app:layout_constraintTop_toTopOf="@id/imageDetail"
            app:layout_constraintStart_toStartOf="@id/imageDetail"
            app:layout_constraintEnd_toEndOf="@id/imageDetail"/>

        <!-- Back button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Favourite button -->
        <ImageView
            android:id="@+id/btnFavorite"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:padding="8dp"
            android:src="@android:drawable/btn_star_big_off"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Title on image -->
        <TextView
            android:id="@+id/textNameDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Boarding House"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_margin="16dp"
            app:layout_constraintBottom_toBottomOf="@id/imageDetail"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Main card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="-30dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:layout_constraintTop_toBottomOf="@id/imageDetail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white">

                <!-- Property type -->
                <TextView
                    android:id="@+id/textTypeDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Boarding House"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:textStyle="italic"/>

                <!-- Price -->
                <TextView
                    android:id="@+id/textPriceDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱2500/month"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="4dp"/>

                <!-- Deposit -->
                <TextView
                    android:id="@+id/textDepositDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deposit: ₱0"
                    android:textSize="13sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginTop="2dp"/>

                <!-- Location -->
                <TextView
                    android:id="@+id/textLocationDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Address here"
                    android:textSize="13sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginTop="8dp"
                    android:drawableStart="@android:drawable/ic_dialog_map"
                    android:drawablePadding="6dp"/>

                <!-- Specs -->
                <TextView
                    android:id="@+id/textSpecsDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👥 guests • 🛏 bedrooms • 🚿 bathrooms"
                    android:textSize="13sp"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="8dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:alpha="0.2"
                    android:layout_marginVertical="12dp"/>

                <!-- Description label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About this place"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/textDescriptionDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description..."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="6dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:alpha="0.2"
                    android:layout_marginVertical="12dp"/>

                <!-- Amenities -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amenities"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>

                <TextView
                    android:id="@+id/textServicesDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WiFi, Water..."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="6dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:alpha="0.2"
                    android:layout_marginVertical="12dp"/>

                <!-- Rules -->
                <TextView
                    android:id="@+id/textRulesDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="House Rules: ..."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- UNITS CHIP — tap to open UnitsActivity             -->
                <!-- Hidden until units load from server                -->
                <!-- ══════════════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardUnitsChip"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:strokeColor="#6366F1"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🏠"
                            android:textSize="22sp"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="10"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:id="@+id/tvUnitsChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3 units available"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#3730A3"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap to browse individual rooms"
                                android:textSize="12sp"
                                android:textColor="#6366F1"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="24sp"
                            android:textColor="#6366F1"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>
                <!-- ══════════════════════════════════════════════════ -->

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:alpha="0.2"
                    android:layout_marginVertical="12dp"/>

                <!-- Contact section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Owner"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>

                <TextView
                    android:id="@+id/textContactName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👤 Name"
                    android:textSize="13sp"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/textContactEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✉ email"
                    android:textSize="13sp"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/textContactPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📞 phone"
                    android:textSize="13sp"
                    android:textColor="@color/textPrimary"
                    android:layout_marginTop="4dp"/>

                <!-- Action buttons -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReserve"
                        android:text="Reserve Now"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/primary"
                        android:textColor="@android:color/white"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="textStart"
                        app:cornerRadius="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMessage"
                        android:text="Message Owner"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:icon="@android:drawable/ic_dialog_email"
                        app:cornerRadius="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMap"
                        android:text="View on Map"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:icon="@android:drawable/ic_dialog_map"
                        app:cornerRadius="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDelete"
                        android:text="Delete Listing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:backgroundTint="#FF5252"
                        android:textColor="@android:color/white"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconGravity="textStart"
                        app:cornerRadius="16dp"
                        android:visibility="visible"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>