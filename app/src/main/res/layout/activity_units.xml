<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top bar -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/white"
            android:gravity="center_vertical"
            android:elevation="4dp"
            android:padding="8dp">

            <ImageView
                android:id="@+id/btnBackUnits"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"/>

            <TextView
                android:id="@+id/tvUnitsPropertyName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Available Units"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:ellipsize="end"
                android:maxLines="1"/>

            <!-- Counter badge -->
            <TextView
                android:id="@+id/tvUnitsCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 of 3"
                android:textSize="13sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:background="@drawable/bg_chip_purple"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>

        </LinearLayout>

        <!-- Unit photo -->
        <ImageView
            android:id="@+id/ivUnitPhoto"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/test2"
            android:visibility="visible"/>

        <!-- Unit detail card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:background="@color/white">

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tvUnitStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Available"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Unit name -->
                <TextView
                    android:id="@+id/tvUnitName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Room 1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>

                <!-- Price -->
                <TextView
                    android:id="@+id/tvUnitPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0/month"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="4dp"/>

                <!-- Deposit -->
                <TextView
                    android:id="@+id/tvUnitDeposit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deposit: ₱0"
                    android:textSize="13sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginTop="2dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@android:color/darker_gray"
                    android:alpha="0.2"
                    android:layout_marginVertical="14dp"/>

                <!-- Description label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About this unit"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/tvUnitDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Reserve button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReserveUnit"
            android:text="Reserve This Unit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/primary"
            android:textColor="@android:color/white"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMakeUnitAvailable"
            android:text="Make Unit Available"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@android:drawable/ic_menu_rotate"
            app:iconGravity="textStart"
            app:cornerRadius="16dp"/>

        <!-- Prev / Next navigation -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnitPrev"
                android:text="← Previous"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="12dp"/>

            <View
                android:layout_width="12dp"
                android:layout_height="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnitNext"
                android:text="Next →"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#6366F1"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>