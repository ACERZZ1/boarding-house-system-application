<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:background="#F5F5F5">

    <EditText
        android:id="@+id/etUnitName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Unit Name (e.g. Room 1)"
        android:inputType="text"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etUnitPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Price per month (₱)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etUnitDeposit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Deposit (₱) — optional"
        android:inputType="numberDecimal"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etUnitDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description — optional"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPickUnitImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📷 Pick Photo"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnRemoveUnit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑 Remove"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>